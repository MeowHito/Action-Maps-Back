# ---- App ----
PORT=3001
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5500

# ---- Database ----
MONGODB_URI=mongodb://127.0.0.1:27017/route_tracker

# ---- Storage ----
# STORAGE_DRIVER: "local" | "s3"
STORAGE_DRIVER=local

# Local storage (served at /uploads)
LOCAL_UPLOAD_DIR=./uploads
PUBLIC_BASE_URL=http://localhost:3001

# S3 / S3-compatible (MinIO, R2, etc.)
S3_ENDPOINT=
S3_REGION=ap-southeast-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=false
S3_PUBLIC_URL=

# ---- Upload limits ----
MAX_PHOTO_SIZE_MB=12
MAX_GPX_SIZE_MB=10
